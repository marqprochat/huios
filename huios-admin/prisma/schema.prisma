// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                   String   @id @default(uuid())
  name                 String
  email                String   @unique
  phone                String?
  userId               String?  @unique
  user                 User?    @relation(fields: [userId], references: [id])
  cpf                  String?  @unique
  address              String?

  // Novos campos pessoais
  birthDate            DateTime?
  maritalStatus        String?  // SOLTEIRO, CASADO, DIVORCIADO, VIUVO

  // Campos espirituais
  conversionTime       String?  // Ex: "2 anos", "5 meses"
  churchName           String?  // Qual igreja frequenta
  churchMembershipTime String?  // Há quanto tempo é membro
  isBaptized           Boolean  @default(false)
  baptismTime          String?  // Há quanto tempo é batizado

  // Campos de matrícula
  howKnewHuios         String?  // Como conheceu o Huios Avançado
  enrollmentFee        Float?   // Taxa de Matrícula
  didConvivaCourse     Boolean  @default(false) // Fez algum curso na Igreja Conviva?
  convivaCourseDetails String?  // Quais cursos fez

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  enrollments Enrollment[]
  teamMembers TeamMember[]

  // Relações novas
  submissions ExamSubmission[]
  attendances Attendance[]
  grades Grade[]
  absenceJustifications AbsenceJustification[]
  financialTransactions FinancialTransaction[]

  // Vínculos de matrícula
  familyId String?
  family   Family?  @relation(fields: [familyId], references: [id])
  churchId String?
  church   Church?  @relation(fields: [churchId], references: [id])
}

model Teacher {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  cpf       String?  @unique
  city      String?
  pixType   String?
  pix       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  classes     Class[]
  disciplines Discipline[]
  financialTransactions FinancialTransaction[]
}

model TeamMember {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  phone         String?
  cpf           String?  @unique
  birthDate     DateTime?
  maritalStatus String?  // SOLTEIRO, CASADO, DIVORCIADO, VIUVO
  address       String?
  area          String?
  role          String   @default("MONITOR") // MONITOR, LIDER_DE_TURMA, VOLUNTARIO
  studentId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student       Student? @relation(fields: [studentId], references: [id])
}

model Module {
  id          String   @id @default(uuid())
  name        String
  description String?
  workload    Int      // em horas
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  classes     Class[]
}

model Class {
  id          String   @id @default(uuid())
  name        String
  location    String?  // Pólo
  startDate   DateTime?
  endDate     DateTime?
  moduleId    String
  teacherId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module      Module   @relation(fields: [moduleId], references: [id])
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  classId   String
  status    String   @default("CURSANDO") // CURSANDO, TRANCADO, APROVADO, REPROVADO
  statusDate DateTime? @default(now())
  statusReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Contexto de preço / origem da matrícula
  priceTier     String?  // MEMBER, NON_MEMBER, FAMILY, PARTNER
  monthlyAmount Float?   // valor da mensalidade aplicado
  churchId      String?
  church        Church?  @relation(fields: [churchId], references: [id])
  origin        String   @default("ADMIN") // ADMIN, PUBLIC_LINK

  student   Student  @relation(fields: [studentId], references: [id])
  class     CourseClass @relation(fields: [classId], references: [id])
  financialTransactions FinancialTransaction[]

  @@unique([studentId, classId])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ALUNO") // ALUNO, MONITOR, COORDENADOR, SUPER_ADMIN
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student?
}

model Course {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?  // URL da imagem do curso
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  modality    String   @default("POR_NOTA") // POR_NOTA, POR_PRESENCA
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  classes     CourseClass[]
  coursePrice CoursePrice?
}

model CourseClass {
  id          String   @id @default(uuid())
  name        String
  startDate   DateTime?
  endDate     DateTime?
  duration    String?  // Tempo da turma, ex: "2 anos", "6 meses"
  courseId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Controle de matrícula
  enrollmentStatus   String    @default("FECHADA") // ABERTA, FECHADA
  enrollmentOpensAt  DateTime?
  enrollmentClosesAt DateTime?
  installments       Int       @default(1) // qtd de mensalidades a gerar
  vacancies          Int?      // vagas (opcional)

  course      Course       @relation(fields: [courseId], references: [id])
  disciplines Discipline[]
  enrollments Enrollment[]
}

model Discipline {
  id String @id @default(uuid())
  name String
  description String?
  workload Int? // em horas
  year Int? // Ano letivo (ex: 2026)
  teacherId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseClasses CourseClass[] // N:N implícito
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  // Relações novas
  exams Exam[]
  lessons Lesson[]
  grades Grade[]
  evaluations TeacherEvaluation[]
  absenceJustifications AbsenceJustification[]
}

// ============================================================
// MODELOS DE PROVAS E QUESTÕES
// ============================================================

model Exam {
  id String @id @default(uuid())
  title String
  description String?
  disciplineId String
  discipline Discipline @relation(fields: [disciplineId], references: [id])

  // Janela de tempo
  startDate DateTime
  endDate DateTime

  // Configurações
  duration Int? // Duração em minutos (opcional - se quiser limitar tempo)
  maxAttempts Int @default(1)
  isPublished Boolean @default(false)

  // Relações
  questions Question[]
  submissions ExamSubmission[]
  grades Grade[] // Para vincular notas automáticas

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id String @id @default(uuid())
  examId String
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  // Conteúdo
  statement String // Enunciado
  type QuestionType @default(MULTIPLE_CHOICE)
  order Int @default(0) // Ordem da questão na prova

  // Configuração de peso
  weight Float @default(1.0) // Peso da questão no total

  // Relações
  alternatives Alternative[]
  answers StudentAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alternative {
  id String @id @default(uuid())
  questionId String
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  letter String // A, B, C, D, E
  text String
  isCorrect Boolean @default(false)

  // Relação com respostas
  answers StudentAnswer[]

  createdAt DateTime @default(now())
}

// Respostas dos alunos
model ExamSubmission {
  id String @id @default(uuid())
  examId String
  exam Exam @relation(fields: [examId], references: [id])
  studentId String
  student Student @relation(fields: [studentId], references: [id])

  startedAt DateTime @default(now())
  submittedAt DateTime?

  score Float?
  maxScore Float?

  answers StudentAnswer[]

  @@unique([examId, studentId]) // Um aluno só pode submeter uma vez
}

model StudentAnswer {
  id String @id @default(uuid())
  submissionId String
  submission ExamSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  questionId String
  question Question @relation(fields: [questionId], references: [id])

  alternativeId String?
  alternative Alternative? @relation(fields: [alternativeId], references: [id])

  isCorrect Boolean?
  points Float?

  @@unique([submissionId, questionId]) // Uma resposta por questão por submissão
}

enum QuestionType {
  MULTIPLE_CHOICE
  // OPEN_TEXT      // Futuro
  // FILE_UPLOAD    // Futuro
}

// ============================================================
// MODELOS DE AULAS E PRESENÇA
// ============================================================

model Lesson {
  id String @id @default(uuid())
  
  // Relações
  disciplines Discipline[]

  // Data e horário
  date DateTime
  startTime DateTime?
  endTime DateTime?

  // Localização para check-in
  locationName String? // Nome do local (ex: "Auditório Principal")
  latitude Float?
  longitude Float?
  radiusMeters Int @default(100) // Raio de tolerância em metros

  // Observações
  description String?

  // Relações
  attendances Attendance[]
  materials   LessonMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id String @id @default(uuid())
  lessonId String
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  studentId String
  student Student @relation(fields: [studentId], references: [id])

  // Status
  status AttendanceStatus @default(PENDING)

  // Check-in (pode ser automático ou manual)
  checkInAt DateTime?
  checkInLat Float?
  checkInLong Float?
  distance Float? // Distância calculada em metros

  // Check-out
  checkOutAt DateTime?
  checkOutLat Float?
  checkOutLong Float?
  checkOutDistance Float?

  // Lançamento manual
  markedById String? // ID do usuário que marcou (se manual)
  markedAt DateTime?
  notes String? // Observações

  justification AbsenceJustification?

  @@unique([lessonId, studentId]) // Um aluno por aula
}

enum AttendanceStatus {
  PRESENT // Presente
  ABSENT // Ausente
  EXCUSED // Justificado
  PENDING // Aguardando
}

model LessonMaterial {
  id            String   @id @default(uuid())
  lessonId      String
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  fileName      String
  filePath      String
  fileSize      Int
  mimeType      String
  description   String?
  uploadedById  String?
  createdAt     DateTime @default(now())
}

// ============================================================
// MODELOS DE NOTAS E BOLETINS
// ============================================================

model Grade {
  id String @id @default(uuid())
  studentId String
  student Student @relation(fields: [studentId], references: [id])
  disciplineId String
  discipline Discipline @relation(fields: [disciplineId], references: [id])

  // Origem da nota
  type GradeType
  examId String? // Se for de prova online
  exam Exam? @relation(fields: [examId], references: [id])

  // Valores
  score Float // Nota 0-10
  weight Float @default(1.0) // Peso no cálculo da média

  // Identificação (para notas manuais)
  title String? // Ex: "Trabalho de Grupo", "Participação"

  // Metadados
  description String?
  createdById String // Quem criou/lançou a nota
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, disciplineId])
}

model SystemSettings {
  id String @id @default(uuid())
  
  // Localização padrão da instituição
  institutionName String @default("Huios Seminário Teológico")
  locationName String? // Nome do local (ex: "Auditório Principal")
  latitude Float?
  longitude Float?
  radiusMeters Int @default(100) // Raio de tolerância em metros
  
  // Configurações de contato
  contactEmail String? @default("contato@huios.edu.br")
  contactPhone String? @default("(11) 1234-5678")

  // Provedor de pagamento ativo: "pagbank" | "santander"
  paymentProvider String? @default("pagbank")

  // Pagamentos (PagBank / PagSeguro)
  pagbankEnv          String? @default("sandbox") // "sandbox" (testes) | "prod" (produção)
  pagbankToken        String? // Token de integração (sensível)
  pagbankPublicKey    String? // Chave pública p/ criptografar o cartão no navegador (gerada via API)
  pagbankWebhookToken String? // Token p/ validar a assinatura do webhook
  appUrl              String? // URL pública base (ex: https://huios.igrejaconviva.com.br)

  // Meios de pagamento PagBank habilitados no checkout (o coordenador liga/desliga no painel).
  // Cartão e boleto exigem liberação na conta PagBank; por isso vêm desligados por padrão.
  pagbankCardEnabled   Boolean? @default(false) // Cartão de crédito
  pagbankPixEnabled    Boolean? @default(true)  // Pix
  pagbankBoletoEnabled Boolean? @default(false) // Boleto

  // Pagamentos (Santander — API Pix Bacen, autenticação OAuth2 + mTLS)
  santanderEnv               String?  @default("sandbox") // "sandbox" | "prod"
  santanderClientId          String?  // Client ID do app no portal do desenvolvedor Santander
  santanderClientSecret      String?  // Client Secret (sensível)
  santanderApplicationKey    String?  // Application Key / Developer API Key (header X-Application-Key)
  santanderCertificate       String?  // Certificado de transporte em PEM (.crt/.pem)
  santanderCertificateKey    String?  // Chave privada do certificado em PEM (.key)
  santanderCertificatePassphrase String? // Senha da chave privada, quando cifrada
  santanderPixKey            String?  // Chave PIX recebedora (e-mail, CPF/CNPJ, telefone ou aleatória)
  santanderWebhookConfigured Boolean? @default(false) // Webhook registrado na API do Santander

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GradeType {
  EXAM // Prova online
  MANUAL // Lançamento manual
  ACTIVITY // Atividade/Trabalho
  PARTICIPATION // Participação
}

// ============================================================
// MODELOS DE AVALIAÇÃO DE PROFESSORES
// ============================================================

model TeacherEvaluation {
  id            String   @id @default(uuid())
  disciplineId  String
  discipline    Discipline @relation(fields: [disciplineId], references: [id])
  
  // Perguntas (EXCELENTE, BOA, REGULAR, RUIM)
  clarity       String   // Clareza da explicação
  engagement    String   // Engajamento e metodologia
  mastery       String   // Domínio do conteúdo e interação
  
  observations  String?  // Gostaria de acrescentar alguma observação?
  
  createdAt     DateTime @default(now())
}

model TeacherEvaluationSubmission {
  id            String   @id @default(uuid())
  studentId     String
  disciplineId  String

  createdAt     DateTime @default(now())

  @@unique([studentId, disciplineId])
}

// ============================================================
// JUSTIFICATIVAS DE FALTA E NOTIFICAÇÕES
// ============================================================

model AbsenceJustification {
  id           String   @id @default(uuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  attendanceId String   @unique
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  disciplineId String
  discipline   Discipline @relation(fields: [disciplineId], references: [id])

  fileName     String
  filePath     String
  fileSize     Int
  mimeType     String

  status       JustificationStatus @default(PENDING_REVIEW)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNotes  String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum JustificationStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model Notification {
  id          String   @id @default(uuid())
  type        String
  title       String
  message     String
  targetRole  String   @default("COORDENADOR")
  relatedId   String?
  read        Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())
}

// ============================================================
// MÓDULO FINANCEIRO
// ============================================================

enum FinancialType {
  RECEITA
  DESPESA
}

enum FinancialStatus {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
  ISENTO
}

enum PaymentMethod {
  PIX
  DINHEIRO
  TRANSFERENCIA
  CARTAO
  BOLETO
  OUTRO
}

model FinancialCategory {
  id           String                 @id @default(cuid())
  name         String                 @unique
  type         FinancialType?
  color        String?
  isDefault    Boolean                @default(false)
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  transactions FinancialTransaction[]
}

model CoursePrice {
  id          String   @id @default(cuid())
  courseId    String   @unique
  course      Course   @relation(fields: [courseId], references: [id])
  amount      Float    @default(0) // base / compatibilidade (fallback)
  description String?
  isActive    Boolean  @default(true)

  // Níveis de preço (mensalidade por categoria)
  enrollmentFee        Float?    // taxa de matrícula (opcional)
  enrollmentFeeDueDate DateTime? // vencimento da taxa de matrícula (data fixa); vazio = 7 dias após a matrícula
  amountMember    Float? // membro da SEDE
  amountNonMember Float? // não-membro (default / fallback = amount)
  amountFamily    Float? // família 2+
  amountPartner   Float? // parceira 3+

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FinancialTransaction {
  id            String              @id @default(cuid())
  type          FinancialType
  status        FinancialStatus     @default(PENDENTE)
  amount        Float
  description   String
  dueDate       DateTime
  paidAt        DateTime?
  paymentMethod PaymentMethod?
  notes         String?
  reference     String?

  categoryId    String?
  category      FinancialCategory?  @relation(fields: [categoryId], references: [id])

  studentId     String?
  student       Student?            @relation(fields: [studentId], references: [id])
  enrollmentId  String?
  enrollment    Enrollment?         @relation(fields: [enrollmentId], references: [id])
  teacherId     String?
  teacher       Teacher?            @relation(fields: [teacherId], references: [id])

  payments      Payment[]

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

// ============================================================
// MATRÍCULA: IGREJAS, FAMÍLIAS E PAGAMENTOS (GATEWAY)
// ============================================================

model Church {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("EXTERNA") // SEDE (Conviva), PARCEIRA, EXTERNA
  isPartner   Boolean  @default(false)
  publicSlug  String?  @unique // token do link exclusivo (parceiras)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students    Student[]
  enrollments Enrollment[]
}

model Family {
  id               String   @id @default(cuid())
  name             String   // sobrenome / nome da família
  responsibleName  String?
  responsiblePhone String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members          Student[]
}

model Payment {
  id              String               @id @default(cuid())
  transactionId   String
  transaction     FinancialTransaction @relation(fields: [transactionId], references: [id])
  gateway         String               @default("PAGBANK")
  method          String               // CREDIT_CARD, PIX, BOLETO
  status          String               @default("WAITING") // WAITING, PAID, DECLINED, CANCELED
  amount          Float
  gatewayChargeId String?              @unique
  gatewayOrderId  String?
  pixQrCode       String?              // imagem base64/url
  pixQrCodeText   String?              // copia-e-cola
  boletoUrl       String?
  boletoBarcode   String?
  rawResponse     Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

// ============================================================
// CUPONS DE DESCONTO / ISENÇÃO DE TAXA
// ============================================================

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique // código normalizado em MAIÚSCULAS
  description String?
  isActive    Boolean  @default(true)

  // Efeitos do cupom
  waiveEnrollmentFee Boolean @default(false) // isenta a taxa de matrícula
  discountType       String? // "PERCENT" | "FIXED" | null (só isenta taxa)
  discountValue      Float?  // percentual (0-100) ou valor em R$
  discountMonths     Int?    // nº de mensalidades com desconto; null/0 = todas

  // Restrições de uso
  validFrom     DateTime?
  validUntil    DateTime?
  maxUses       Int?     // limite total de usos; null = ilimitado
  usedCount     Int      @default(0)
  onePerStudent Boolean  @default(false)
  courseIds     String[] @default([]) // vazio = todos os cursos
  classIds      String[] @default([]) // vazio = todas as turmas

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id           String   @id @default(cuid())
  couponId     String
  coupon       Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  code         String
  studentId    String?
  enrollmentId String?
  createdAt    DateTime @default(now())

  @@index([couponId, studentId])
}
