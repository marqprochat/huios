// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                   String   @id @default(uuid())
  name                 String
  email                String   @unique
  phone                String?
  cpf                  String?  @unique
  address              String?

  // Novos campos pessoais
  birthDate            DateTime?
  maritalStatus        String?  // SOLTEIRO, CASADO, DIVORCIADO, VIUVO

  // Campos espirituais
  conversionTime       String?  // Ex: "2 anos", "5 meses"
  churchName           String?  // Qual igreja frequenta
  churchMembershipTime String?  // Há quanto tempo é membro
  isBaptized           Boolean  @default(false)
  baptismTime          String?  // Há quanto tempo é batizado

  // Campos de matrícula
  howKnewHuios         String?  // Como conheceu o Huios Avançado
  enrollmentFee        Float?   // Taxa de Matrícula
  didConvivaCourse     Boolean  @default(false) // Fez algum curso na Igreja Conviva?
  convivaCourseDetails String?  // Quais cursos fez

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  enrollments Enrollment[]
  teamMembers    TeamMember[]
}

model Teacher {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  cpf       String?  @unique
  city      String?
  pixType   String?
  pix       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  classes     Class[]
  disciplines Discipline[]
}

model TeamMember {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  phone         String?
  cpf           String?  @unique
  birthDate     DateTime?
  maritalStatus String?  // SOLTEIRO, CASADO, DIVORCIADO, VIUVO
  address       String?
  area          String?
  role          String   @default("MONITOR") // MONITOR, LIDER_DE_TURMA, VOLUNTARIO
  studentId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student       Student? @relation(fields: [studentId], references: [id])
}

model Module {
  id          String   @id @default(uuid())
  name        String
  description String?
  workload    Int      // em horas
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  classes     Class[]
}

model Class {
  id          String   @id @default(uuid())
  name        String
  location    String?  // Pólo
  startDate   DateTime?
  endDate     DateTime?
  moduleId    String
  teacherId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module      Module   @relation(fields: [moduleId], references: [id])
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  enrollments Enrollment[]
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  classId   String
  status    String   @default("ACTIVE") // ACTIVE, CANCELLED, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student  @relation(fields: [studentId], references: [id])
  class     Class    @relation(fields: [classId], references: [id])

  @@unique([studentId, classId])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ALUNO") // ALUNO, MONITOR, COORDENADOR, SUPER_ADMIN
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?  // URL da imagem do curso
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  classes     CourseClass[]
}

model CourseClass {
  id          String   @id @default(uuid())
  name        String
  startDate   DateTime?
  endDate     DateTime?
  duration    String?  // Tempo da turma, ex: "2 anos", "6 meses"
  courseId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course       @relation(fields: [courseId], references: [id])
  disciplines Discipline[]
}

model Discipline {
  id            String   @id @default(uuid())
  name          String
  description   String?
  workload      Int?     // em horas
  courseClassId String
  teacherId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  courseClass   CourseClass @relation(fields: [courseClassId], references: [id])
  teacher       Teacher?    @relation(fields: [teacherId], references: [id])
}
