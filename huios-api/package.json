{
  "name": "huios-api",
  "version": "1.0.0",
  "description": "Backend API for Huios Admin and Mobile",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "echo \"🚀 Iniciando migrações...\" && npx prisma migrate deploy && echo \"✨ Iniciando seed...\" && npx prisma db seed && echo \"🌐 Iniciando servidor...\" && node dist/index.js",
    "lint": "eslint . --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.12.7",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "prisma": "^6.19.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
