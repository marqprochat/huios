# =============================================================================
# HUIOS — Exemplo de variáveis de ambiente (raiz / docker-compose)
# Copie para `.env` e preencha os valores. NÃO comite o `.env` real.
# =============================================================================

# --- URLs públicas -----------------------------------------------------------
DOMAIN=https://huios.igrejaconviva.com.br
FRONTEND_URL=https://huios.igrejaconviva.com.br
# URL da API consumida pelo navegador (build-arg do admin).
NEXT_PUBLIC_API_URL=https://api.huios.igrejaconviva.com.br

# --- Banco de dados (PostgreSQL) ---------------------------------------------
DB_USER=postgres
DB_PASSWORD=troque-esta-senha
DB_NAME=huios
DB_HOST=db          # nome do serviço no docker-compose; use "localhost" fora do Docker
DB_PORT=5432
# Use DB_HOST=db dentro do Docker; localhost ao rodar Prisma na máquina host.
DATABASE_URL="postgresql://postgres:troque-esta-senha@db:5432/huios?schema=public"

# --- Autenticação ------------------------------------------------------------
JWT_SECRET=troque-por-um-segredo-forte
COOKIE_SECURE=true   # true em produção (HTTPS); false em dev local

# --- PagBank (pagamento online — checkout transparente) ----------------------
# Ambiente: "sandbox" para testes, "prod" para produção.
PAGBANK_ENV=sandbox
# Token de API (Bearer) gerado no painel PagBank/PagSeguro. Uso server-side.
PAGBANK_TOKEN=
# Token usado para validar a assinatura (x-authenticity-token) do webhook.
PAGBANK_WEBHOOK_TOKEN=
# Chave PÚBLICA usada no navegador para criptografar o cartão (PCI SAQ-A-EP).
# É build-arg do Dockerfile.prod — precisa estar setada no momento do build.
NEXT_PUBLIC_PAGBANK_PUBLIC_KEY=
# Após configurar, aponte o webhook no painel PagBank para:
#   https://SEU_DOMINIO/api/pagamentos/webhook/pagbank
