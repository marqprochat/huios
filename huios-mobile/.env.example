# URL da API (web app Next.js)
# Em desenvolvimento com dispositivo físico, use o IP da sua máquina local
# Exemplo: EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
# Em emulador Android: EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
# Em simulador iOS: EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
